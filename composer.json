{
    "name": "makfly/stripe-cashier-bundle",
    "description": "Stripe Cashier integration for Symfony 7 and 8",
    "type": "symfony-bundle",
    "keywords": ["stripe", "cashier", "symfony", "payments"],
    "homepage": "https://github.com/MakFly/stripe-cashier-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Cashier Team",
            "email": "team@cashier.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "dompdf/dompdf": "^3.1",
        "doctrine/doctrine-bundle": "^2.13|^3.0",
        "stripe/stripe-php": "^16.0",
        "symfony/framework-bundle": "^7.0|^8.0",
        "symfony/doctrine-bridge": "^7.0|^8.0",
        "doctrine/orm": "^3.0",
        "nesbot/carbon": "^3.0",
        "moneyphp/money": "^4.5",
        "phpseclib/bcmath_compat": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.66",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0",
        "symfony/phpunit-bridge": "^7.0|^8.0",
        "symfony/var-exporter": "^7.0|^8.0"
    },
    "suggest": {
        "symfony/messenger": "For processing webhooks asynchronously"
    },
    "autoload": {
        "psr-4": {
            "CashierBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CashierBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint:phpstan": "phpstan analyse --configuration=phpstan.neon.dist --no-progress",
        "lint:cs": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --using-cache=no",
        "audit:composer": "composer audit --no-interaction",
        "quality": [
            "@lint:phpstan",
            "@lint:cs",
            "@audit:composer"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
