<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice #{{ invoice.number|default(invoice.id) }}</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            padding: 32px;
            background: #f6f9fc;
            color: #0a2540;
            font-family: Helvetica, Arial, sans-serif;
            font-size: 13px;
            line-height: 1.5;
        }
        .sheet {
            max-width: 860px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #e3e8ee;
            border-radius: 18px;
            padding: 40px;
        }
        .topbar {
            width: 100%;
            margin-bottom: 32px;
        }
        .brand {
            display: inline-block;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #635bff;
        }
        .header-table,
        .summary-table,
        .items-table,
        .meta-table {
            width: 100%;
            border-collapse: collapse;
        }
        .header-table td {
            vertical-align: top;
        }
        .invoice-title {
            text-align: right;
        }
        .eyebrow {
            color: #697386;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }
        .invoice-number {
            font-size: 28px;
            font-weight: 700;
            color: #0a2540;
            margin: 0 0 8px;
        }
        .status-pill {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .status-paid { background: #d1f7dd; color: #0a7f42; }
        .status-open, .status-pending { background: #fff3d6; color: #8b5e00; }
        .status-draft { background: #e6ebf1; color: #566171; }
        .card {
            border: 1px solid #e3e8ee;
            border-radius: 14px;
            padding: 18px 20px;
            background: #fff;
        }
        .grid {
            width: 100%;
            margin-bottom: 28px;
        }
        .grid td {
            width: 50%;
            vertical-align: top;
            padding-right: 12px;
        }
        .grid td:last-child {
            padding-right: 0;
            padding-left: 12px;
        }
        .muted { color: #697386; }
        .strong { font-weight: 700; }
        .meta-table td {
            padding: 2px 0;
            color: #425466;
        }
        .items-table {
            border: 1px solid #e3e8ee;
            border-radius: 14px;
            overflow: hidden;
            margin-bottom: 24px;
        }
        .items-table thead th {
            background: #f6f9fc;
            color: #697386;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            padding: 14px 16px;
            border-bottom: 1px solid #e3e8ee;
            text-align: left;
        }
        .items-table thead th:last-child,
        .items-table tbody td:last-child,
        .summary-table td:last-child {
            text-align: right;
        }
        .items-table tbody td {
            padding: 16px;
            border-bottom: 1px solid #e3e8ee;
            vertical-align: top;
        }
        .items-table tbody tr:last-child td {
            border-bottom: none;
        }
        .qty,
        .price {
            text-align: center;
            width: 110px;
        }
        .summary-wrap {
            width: 100%;
        }
        .summary-offset {
            width: 46%;
        }
        .summary-card {
            width: 54%;
            margin-left: auto;
            border: 1px solid #e3e8ee;
            border-radius: 14px;
            padding: 16px 18px;
        }
        .summary-table td {
            padding: 8px 0;
            color: #425466;
        }
        .summary-table .total td {
            font-size: 18px;
            font-weight: 700;
            color: #0a2540;
            border-top: 1px solid #e3e8ee;
            padding-top: 14px;
        }
        .payment-note,
        .footer {
            margin-top: 22px;
            color: #697386;
        }
        .footer {
            border-top: 1px solid #e3e8ee;
            padding-top: 18px;
            font-size: 12px;
        }
        @media print {
            body {
                padding: 0;
                background: #fff;
            }
            .sheet {
                border: none;
                border-radius: 0;
                padding: 0;
            }
        }
    </style>
</head>
<body>
<div class="sheet">
    <div class="topbar">
        <span class="brand">{{ company.name|default('Stripe-like Invoice') }}</span>
    </div>

    <table class="header-table">
        <tr>
            <td>
                <div class="eyebrow">From</div>
                <div class="strong">{{ company.name|default('Stripe-like Invoice') }}</div>
                {% if company.address %}<div class="muted">{{ company.address|nl2br }}</div>{% endif %}
                {% if company.email %}<div class="muted">{{ company.email }}</div>{% endif %}
                {% if company.phone %}<div class="muted">{{ company.phone }}</div>{% endif %}
            </td>
            <td class="invoice-title">
                <div class="eyebrow">Invoice</div>
                <h1 class="invoice-number">#{{ invoice.number|default(invoice.id) }}</h1>
                <span class="status-pill status-{{ invoice.status|default('paid') }}">{{ invoice.status|default('paid')|upper }}</span>
            </td>
        </tr>
    </table>

    <table class="grid">
        <tr>
            <td>
                <div class="card">
                    <div class="eyebrow">Bill to</div>
                    {% if customer %}
                        {% if customer.name %}<div class="strong">{{ customer.name }}</div>{% endif %}
                        {% if customer.email %}<div class="muted">{{ customer.email }}</div>{% endif %}
                        {% if customer.address %}<div class="muted">{{ customer.address|nl2br }}</div>{% endif %}
                    {% else %}
                        <div class="muted">Customer information unavailable</div>
                    {% endif %}
                </div>
            </td>
            <td>
                <div class="card">
                    <div class="eyebrow">Invoice details</div>
                    <table class="meta-table">
                        <tr>
                            <td>Date issued</td>
                            <td>{{ invoice.date|date('M j, Y') }}</td>
                        </tr>
                        {% if invoice.dueDate %}
                            <tr>
                                <td>Due date</td>
                                <td>{{ invoice.dueDate|date('M j, Y') }}</td>
                            </tr>
                        {% endif %}
                        <tr>
                            <td>Currency</td>
                            <td>{{ invoice.currency|upper }}</td>
                        </tr>
                        <tr>
                            <td>Reference</td>
                            <td>{{ invoice.id }}</td>
                        </tr>
                    </table>
                </div>
            </td>
        </tr>
    </table>

    <table class="items-table">
        <thead>
        <tr>
            <th>Description</th>
            <th class="qty">Qty</th>
            <th class="price">Unit price</th>
            <th>Amount</th>
        </tr>
        </thead>
        <tbody>
        {% for item in invoice.items %}
            <tr>
                <td>
                    <div class="strong">{{ item.description }}</div>
                </td>
                <td class="qty">{{ item.quantity|default(1) }}</td>
                <td class="price">{{ item.unit_amount|stripe_amount(invoice.currency) }}</td>
                <td>{{ item.amount|stripe_amount(invoice.currency) }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="summary-wrap">
        <div class="summary-card">
            <table class="summary-table">
                <tr>
                    <td>Subtotal</td>
                    <td>{{ invoice.subtotal|stripe_amount(invoice.currency) }}</td>
                </tr>
                {% if invoice.tax > 0 %}
                    <tr>
                        <td>Tax</td>
                        <td>{{ invoice.tax|stripe_amount(invoice.currency) }}</td>
                    </tr>
                {% endif %}
                {% for discount in invoice.discounts %}
                    <tr>
                        <td>Discount{% if discount.coupon.name %} · {{ discount.coupon.name }}{% endif %}</td>
                        <td>
                            -{% if discount.coupon.amountOff %}
                                {{ discount.coupon.amountOff|stripe_amount(invoice.currency) }}
                            {% elseif discount.coupon.percentOff %}
                                {{ discount.coupon.percentOff }}%
                            {% else %}
                                0
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                <tr class="total">
                    <td>Total</td>
                    <td>{{ invoice.total|stripe_amount(invoice.currency) }}</td>
                </tr>
            </table>
        </div>
    </div>

    {% if invoice.payment_intent %}
        <div class="payment-note">
            Payment intent: <span class="strong">{{ invoice.payment_intent }}</span>
        </div>
    {% endif %}

    <div class="footer">
        <div class="strong">Thank you for your business.</div>
        {% if footer.text %}<div>{{ footer.text }}</div>{% endif %}
        {% if footer.support_email %}<div>Support: {{ footer.support_email }}</div>{% endif %}
        <div>Generated on {{ 'now'|date('M j, Y H:i') }}</div>
    </div>
</div>
</body>
</html>
