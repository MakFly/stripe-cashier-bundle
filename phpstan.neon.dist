parameters:
  level: 6
  paths:
    - src
    - tests
  excludePaths:
    analyse:
      - src/Repository/*
      - src/Twig/CashierExtension.php
  tmpDir: var/phpstan
  treatPhpDocTypesAsCertain: false
  reportUnmatchedIgnoredErrors: false

includes:
  - phpstan-baseline.neon
  - phpstan-baseline-extra.neon
