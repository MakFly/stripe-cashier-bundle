---
import '../styles/global.css';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="CashierBundle - Stripe Cashier pour Symfony 8.X" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>CashierBundle - Stripe Cashier pour Symfony 8.X</title>
  </head>

  <body class="min-h-screen bg-slate-900 text-white">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800 bg-slate-900/95 backdrop-blur">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center gap-8">
            <a href="/" class="flex items-center gap-2">
              <svg class="h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="currentColor">
                <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
              </svg>
              <span class="text-xl font-bold">CashierBundle</span>
            </a>
            <div class="hidden md:flex items-center gap-6">
              <a href="/docs/installation" class="text-sm text-slate-300 hover:text-white transition">Documentation</a>
              <a href="/docs/subscriptions" class="text-sm text-slate-300 hover:text-white transition">Abonnements</a>
              <a href="/docs/webhooks" class="text-sm text-slate-300 hover:text-white transition">Webhooks</a>
              <a href="https://github.com/cashier/cashier-bundle" class="text-sm text-slate-300 hover:text-white transition">GitHub</a>
            </div>
          </div>
          <a href="/docs/installation" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition">
            Commencer
          </a>
        </div>
      </nav>
    </header>

    <!-- Hero -->
    <section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-32">
      <div class="absolute inset-0 -z-10">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-900/20 via-slate-900 to-slate-900"></div>
        <div class="absolute top-0 right-0 h-96 w-96 bg-indigo-500/10 blur-3xl"></div>
      </div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-indigo-500/10 px-4 py-2 text-sm text-indigo-400">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo-500"></span>
            </span>
            v1.0.0 - Symfony 8.X Compatible
          </div>

          <h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-6xl lg:text-7xl">
            <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">
              Stripe Cashier
            </span>
            <br />pour Symfony
          </h1>

          <p class="mx-auto mb-10 max-w-2xl text-lg text-slate-400 sm:text-xl">
            Gérez vos abonnements Stripe avec élégance. Un portage complet de Laravel Cashier pour Symfony 8.X.
          </p>

          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a href="/docs/installation" class="w-full rounded-lg bg-indigo-600 px-8 py-4 text-center text-lg font-semibold text-white shadow-lg shadow-indigo-500/25 hover:bg-indigo-500 transition sm:w-auto">
              Commencer maintenant
            </a>
            <a href="https://github.com/cashier/cashier-bundle" class="w-full rounded-lg border border-slate-700 bg-slate-800/50 px-8 py-4 text-center text-lg font-semibold hover:bg-slate-800 transition sm:w-auto">
              Voir sur GitHub
            </a>
          </div>
        </div>

        <!-- Code Example -->
        <div class="mx-auto mt-16 max-w-3xl">
          <div class="rounded-xl border border-slate-800 bg-slate-900/80 p-1">
            <div class="flex items-center gap-2 border-b border-slate-800 px-4 py-2">
              <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-red-500/80"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500/80"></div>
                <div class="h-3 w-3 rounded-full bg-green-500/80"></div>
              </div>
              <span class="ml-2 text-sm text-slate-500">subscription.php</span>
            </div>
            <pre class="overflow-x-auto p-4 text-sm"><code><span class="text-purple-400">$subscription</span> = <span class="text-purple-400">$user</span>->newSubscription(<span class="text-green-400">'default'</span>, <span class="text-green-400">'price_premium'</span>)
    ->trialDays(<span class="text-orange-400">14</span>)
    ->create(<span class="text-purple-400">$paymentMethodId</span>);

<span class="text-purple-400">if</span> (<span class="text-purple-400">$user</span>->subscribed(<span class="text-green-400">'default'</span>)) {
    <span class="text-slate-500">// Accès au contenu premium</span>
}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="border-t border-slate-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold sm:text-4xl">Tout ce dont vous avez besoin</h2>
          <p class="mt-4 text-lg text-slate-400">Une solution complète pour gérer les paiements récurrents</p>
        </div>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-indigo-500/50 transition">
            <div class="mb-4 inline-flex rounded-lg bg-indigo-500/10 p-3">
              <svg class="h-6 w-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold">Abonnements</h3>
            <p class="text-slate-400">Création, annulation, reprise et changement de plan.</p>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-indigo-500/50 transition">
            <div class="mb-4 inline-flex rounded-lg bg-green-500/10 p-3">
              <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold">Périodes d'essai</h3>
            <p class="text-slate-400">Essais gratuits configurables avec suivi automatique.</p>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-indigo-500/50 transition">
            <div class="mb-4 inline-flex rounded-lg bg-purple-500/10 p-3">
              <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold">Paiements</h3>
            <p class="text-slate-400">Charges ponctuels et récurrents avec remboursements.</p>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-indigo-500/50 transition">
            <div class="mb-4 inline-flex rounded-lg bg-cyan-500/10 p-3">
              <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold">Factures PDF</h3>
            <p class="text-slate-400">Génération automatique de factures professionnelles.</p>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-indigo-500/50 transition">
            <div class="mb-4 inline-flex rounded-lg bg-orange-500/10 p-3">
              <svg class="h-6 w-6 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold">Coupons</h3>
            <p class="text-slate-400">Codes promotionnels avec réductions en % ou montant fixe.</p>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-indigo-500/50 transition">
            <div class="mb-4 inline-flex rounded-lg bg-pink-500/10 p-3">
              <svg class="h-6 w-6 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold">Webhooks</h3>
            <p class="text-slate-400">10 handlers intégrés pour synchroniser vos données.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-slate-800 py-12">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
          <span class="text-sm text-slate-400">CashierBundle - MIT License</span>
          <div class="flex items-center gap-6">
            <a href="https://stripe.com/docs" class="text-sm text-slate-400 hover:text-white transition">Stripe Docs</a>
            <a href="https://symfony.com/doc" class="text-sm text-slate-400 hover:text-white transition">Symfony Docs</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
