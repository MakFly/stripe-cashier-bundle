---
import '../../styles/global.css';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Abonnements | CashierBundle</title>
  </head>

  <body class="min-h-screen bg-slate-900 text-white">
    <div class="flex">
      <aside class="fixed left-0 top-16 h-[calc(100vh-4rem)] w-64 border-r border-slate-800 bg-slate-900/95 overflow-y-auto p-4">
        <nav class="space-y-1">
          <a href="/docs/installation" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Installation</a>
          <a href="/docs/configuration" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Configuration</a>
          <a href="/docs/subscriptions" class="block rounded-lg bg-indigo-500/10 px-3 py-2 text-sm font-medium text-indigo-400">Abonnements</a>
          <a href="/docs/payments" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Paiements</a>
          <a href="/docs/invoices" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Factures</a>
          <a href="/docs/webhooks" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Webhooks</a>
          <a href="/docs/checkout" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Checkout</a>
          <a href="/docs/coupons" class="block rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-white hover:bg-slate-800">Coupons</a>
        </nav>
      </aside>

      <main class="ml-64 flex-1 p-8 pt-24">
        <div class="mx-auto max-w-3xl">
          <h1 class="text-4xl font-bold mb-6">Gestion des Abonnements</h1>

          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">Créer un abonnement</h2>
            <pre class="rounded-lg bg-slate-800 p-4 overflow-x-auto"><code class="text-sm">$user = $userRepository->find(1);

$subscription = $user->newSubscription('default', 'price_premium')
    ->trialDays(14)
    ->create($paymentMethodId);</code></pre>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">Vérifier un abonnement</h2>
            <pre class="rounded-lg bg-slate-800 p-4 overflow-x-auto"><code class="text-sm">if ($user->subscribed('default')) {
    // L'utilisateur est abonné
}

if ($user->onTrial('default')) {
    // L'utilisateur est en période d'essai
}

if ($user->subscription('default')->cancelled()) {
    // L'abonnement est annulé
}</code></pre>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">Changer de plan</h2>
            <pre class="rounded-lg bg-slate-800 p-4 overflow-x-auto"><code class="text-sm">$user->subscription('default')
    ->swap('price_enterprise');

// Sans proration
$user->subscription('default')
    ->noProrate()
    ->swap('price_enterprise');</code></pre>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">Annuler un abonnement</h2>
            <pre class="rounded-lg bg-slate-800 p-4 overflow-x-auto"><code class="text-sm">// Annuler à la fin de la période
$user->subscription('default')->cancel();

// Annuler immédiatement
$user->subscription('default')->cancelNow();

// Reprendre un abonnement annulé
$user->subscription('default')->resume();</code></pre>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">Période d'essai</h2>
            <pre class="rounded-lg bg-slate-800 p-4 overflow-x-auto"><code class="text-sm">// 14 jours d'essai
$user->newSubscription('default', 'price_premium')
    ->trialDays(14)
    ->create($paymentMethodId);

// Essai jusqu'à une date spécifique
$user->newSubscription('default', 'price_premium')
    ->trialUntil(Carbon::parse('2024-12-31'))
    ->create($paymentMethodId);</code></pre>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">Statuts disponibles</h2>
            <div class="rounded-lg bg-slate-800 p-4">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left border-b border-slate-700">
                    <th class="pb-2">Méthode</th>
                    <th class="pb-2">Description</th>
                  </tr>
                </thead>
                <tbody class="text-slate-400">
                  <tr class="border-b border-slate-700/50"><td class="py-2"><code>active()</code></td><td>Abonnement actif ou en essai</td></tr>
                  <tr class="border-b border-slate-700/50"><td class="py-2"><code>onTrial()</code></td><td>En période d'essai</td></tr>
                  <tr class="border-b border-slate-700/50"><td class="py-2"><code>cancelled()</code></td><td>Abonnement annulé</td></tr>
                  <tr class="border-b border-slate-700/50"><td class="py-2"><code>onGracePeriod()</code></td><td>Annulé mais encore actif</td></tr>
                  <tr class="border-b border-slate-700/50"><td class="py-2"><code>pastDue()</code></td><td>Paiement en retard</td></tr>
                  <tr><td class="py-2"><code>incomplete()</code></td><td>Paiement initial échoué</td></tr>
                </tbody>
              </table>
            </div>
          </section>

          <div class="flex justify-between mt-12 pt-8 border-t border-slate-800">
            <a href="/docs/configuration" class="text-indigo-400 hover:text-indigo-300">&larr; Configuration</a>
            <a href="/docs/payments" class="text-indigo-400 hover:text-indigo-300">Paiements &rarr;</a>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
